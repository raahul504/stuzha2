{
  "appId": "com.dcs.lms",
  "productName": "DataCentreSkills",
  "directories": {
    "output": "../dist-electron"
  },
  "files": [
    "main.js",
    "preload.js"
  ],
  "extraResources": [
    {
      "from": "../frontend/dist",
      "to": "frontend/dist"
    }
  ],
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "../frontend/src/assets/DCS_Skills_logo.png"
  },
  "forceCodeSigning": false,
  "mac": {
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "protocols": [
    {
      "name": "dcs-video",
      "schemes": [
        "dcs-video"
      ]
    }
  ],
  "asar": false
}